on:
  schedule:
    - cron: '0 9 * * *'  # सुबह 9 बजे
    - cron: '0 14 * * *' # दोपहर 2 बजे
    - cron: '0 18 * * *' # शाम 6 बजे
  workflow_dispatch:      # यह आपको मैन्युअली चलाने की भी सुविधा देता है

jobs:
  build:
    runs-on: ubuntu-latest
    steps:
      - name: Checkout code
        uses: actions/checkout@v3

      - name: Set up Python
        uses: actions/setup-python@v4
        with:
          python-version: '3.9'

      - name: Install dependencies
        run: |
          pip install google-generativeai gtts moviepy google-auth google-auth-oauthlib google-api-python-client

      - name: Run Automation
        env:
          GEMINI_API_KEY: ${{ secrets.GEMINI_API_KEY }}
          CLIENT_SECRET_JSON: ${{ secrets.CLIENT_SECRET_JSON }}
          TOKEN_PICKLE_BASE64: ${{ secrets.TOKEN_PICKLE_BASE64 }}
        run: |
          python main.py
